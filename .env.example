# ─────────────────────────────────────────────
# DATABASE (Supabase)
# ─────────────────────────────────────────────

# Для запросов приложения — берётся из:
# Supabase → Settings → Database → Connection pooling → Mode: Transaction → Connection string
# Порт будет 6543, хост вида: aws-0-eu-central-1.pooler.supabase.com
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Для миграций Prisma — берётся из:
# Supabase → Settings → Database → Connection string → URI (прямое подключение)
# Порт 5432, хост вида: db.XXXXX.supabase.co
DIRECT_URL="postgresql://postgres:PASSWORD@db.XXXXX.supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────

# Случайная строка для подписи токенов. Сгенерировать:
# openssl rand -base64 32
JWT_SECRET="сюда-вставить-результат-openssl"

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────

# Создать на: console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID → Web application
GOOGLE_CLIENT_ID="XXXXXXXXXX.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-XXXXXXXXXX"

# Не менять — это адрес нашего NestJS сервера
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# ─────────────────────────────────────────────
# SUPABASE STORAGE (для загрузки фото)
# ─────────────────────────────────────────────

# Supabase → Settings → API → Project URL
SUPABASE_URL="https://XXXXX.supabase.co"

# Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# ─────────────────────────────────────────────
# NEXT.JS (публичные переменные — видны в браузере)
# ─────────────────────────────────────────────

# Адрес NestJS бэкенда (не менять для локальной разработки)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Адрес самого Next.js фронтенда (не менять для локальной разработки)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
